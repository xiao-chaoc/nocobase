# car-rental isolated PostgreSQL Collection execute test environment template.
# This example file is safe to commit. Copy it to .env.car-rental-collection-test for local use.
# Do not commit .env.car-rental-collection-test, backup dumps, SQL dumps, or real secrets.

DB_DIALECT=postgres
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=nocobase_car_rental_collection_test
DB_USER=nocobase_car_rental_test_user
DB_PASSWORD=TEST_ONLY_CHANGE_ME
DB_SCHEMA=public

# postgres:16 container bootstrap values. Keep these aligned with DB_* values in the local env file.
POSTGRES_DB=nocobase_car_rental_collection_test
POSTGRES_USER=nocobase_car_rental_test_user
POSTGRES_PASSWORD=TEST_ONLY_CHANGE_ME

CAR_RENTAL_DATABASE_SAFETY_LABEL=isolated_test_database
CAR_RENTAL_MOCK_DATA_ONLY=true
IOPGPS_SYNC_ENABLED=false
CAR_RENTAL_COLLECTION_EXECUTE_ENABLED=false
